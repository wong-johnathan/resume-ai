{
  "manifest_version": 3,
  "name": "Save Job",
  "version": "1.0.0",
  "description": "Save any job listing to your resume-app account with one click.",
  "permissions": [
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Save Job"
  }
}
