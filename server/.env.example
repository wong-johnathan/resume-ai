# ─── Supabase / PostgreSQL ────────────────────────────────────────────────────
# DATABASE_URL → Transaction pooler (port 6543) – used by the app at runtime
# DIRECT_URL   → Direct connection (port 5432)  – used by Prisma CLI for migrations
#
# Find both in: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.syszpslgxnmpyqtctcso.supabase.co:5432/postgres

SESSION_SECRET=change-me-to-a-32-plus-character-random-string
OPENAI_API_KEY=sk-...

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback

NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
