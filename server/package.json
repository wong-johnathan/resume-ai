{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/migrate-if-changed.sh && nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "bash scripts/migrate-if-changed.sh",
    "migrate:force": "prisma migrate dev",
    "studio": "prisma studio",
    "db:generate": "prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/pg": "^8.18.0",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "puppeteer": "^23.11.1",
    "stripe": "^21.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/passport": "^1.0.16",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
